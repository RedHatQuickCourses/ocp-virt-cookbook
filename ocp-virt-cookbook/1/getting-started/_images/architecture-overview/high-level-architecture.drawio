<mxfile>
  <diagram name="High-Level Architecture" id="arch1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- OpenShift Cluster boundary -->
        <mxCell id="cluster" value="OpenShift Cluster" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=16;verticalAlign=top;align=center;spacingTop=5;dashed=0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1120" height="620" as="geometry"/>
        </mxCell>

        <!-- Control Plane -->
        <mxCell id="cp" value="Control Plane" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;verticalAlign=top;align=center;spacingTop=5;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="80" y="60" width="1040" height="130" as="geometry"/>
        </mxCell>

        <!-- openshift-cnv namespace -->
        <mxCell id="cnv_ns" value="openshift-cnv namespace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=2;fontSize=11;verticalAlign=top;align=left;spacingTop=3;spacingLeft=8;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="90" width="700" height="85" as="geometry"/>
        </mxCell>

        <!-- HyperConverged CR -->
        <mxCell id="hco" value="HyperConverged CR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="115" y="115" width="130" height="45" as="geometry"/>
        </mxCell>

        <!-- KubeVirt Operator -->
        <mxCell id="kubevirt" value="KubeVirt&#xa;Operator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="265" y="115" width="100" height="45" as="geometry"/>
        </mxCell>

        <!-- CDI Operator -->
        <mxCell id="cdi" value="CDI&#xa;Operator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="115" width="100" height="45" as="geometry"/>
        </mxCell>

        <!-- SSP Operator -->
        <mxCell id="ssp" value="SSP&#xa;Operator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="495" y="115" width="100" height="45" as="geometry"/>
        </mxCell>

        <!-- Network Addons Operator -->
        <mxCell id="netaddons" value="Network Addons&#xa;Operator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="610" y="115" width="110" height="45" as="geometry"/>
        </mxCell>

        <!-- virt-api and virt-controller -->
        <mxCell id="virtapi" value="virt-api" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="95" width="90" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="virtctrl" value="virt-controller" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="950" y="95" width="110" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="cplabel" value="Cluster Services" style="text;html=1;fontSize=10;fontStyle=2;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="870" y="135" width="120" height="20" as="geometry"/>
        </mxCell>

        <!-- Arrow from HCO to operators -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="hco" target="kubevirt">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Worker Node 1 -->
        <mxCell id="w1" value="Worker Node 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#333333;fontStyle=1;fontSize=12;verticalAlign=top;align=center;spacingTop=5;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="80" y="220" width="500" height="280" as="geometry"/>
