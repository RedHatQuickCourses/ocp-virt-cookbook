        <mxCell id="qemu1" value="QEMU/KVM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="410" width="120" height="40" as="geometry"/>
