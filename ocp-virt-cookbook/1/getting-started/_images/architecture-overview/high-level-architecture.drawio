        <mxCell id="leg3t" value="Operators (openshift-cnv)" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="495" y="593" width="160" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="670" y="595" width="20" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="leg4t" value="KubeVirt control plane" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="695" y="593" width="140" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
