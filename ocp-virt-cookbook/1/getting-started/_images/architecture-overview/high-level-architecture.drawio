        <!-- Shared Storage bar -->
        <mxCell id="storage" value="Shared Storage (PVCs / CSI Drivers)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="530" width="540" height="40" as="geometry"/>
