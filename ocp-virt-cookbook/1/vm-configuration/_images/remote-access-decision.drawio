        <mxCell id="console-desc" value="Works without network.&#xa;Troubleshooting, initial setup." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="195" height="30" as="geometry" />
        </mxCell>

        <!-- Q2: Temporary/debugging? -->
