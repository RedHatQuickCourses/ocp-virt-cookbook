          <mxGeometry x="440" y="55" width="190" height="50" as="geometry" />
        </mxCell>

        <!-- Q1: Need network access? -->
        <mxCell id="q1" value="Need network&#xa;access to the VM?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;" vertex="1" parent="1">
