        <!-- Q1: Single or multi-node? -->
        <mxCell id="q1" value="Single-node or&#xa;multi-node cluster?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
